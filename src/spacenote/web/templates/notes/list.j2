{% extends "base.j2" %}
{% block content %}
<nav>
  <ul>
    <li>
      <h1>Notes / {{space.name}}</h1>
    </li>
  </ul>
  <ul>
    <li><a href="/notes/{{space.id}}/create">Create</a></li>
  </ul>
</nav>

<table>
  <thead>
    <tr>
      <th>id</th>
      <th>author</th>
      <th>created at</th>
      {% for field_name in space.list_fields %}
      <th>{{field_name}}</th>
      {% endfor %}
    </tr>
  </thead>
  {% for note in notes%}
  <tr>
    <td>
      <a href="/notes/{{space.id}}/{{note.id}}">#{{note.id}}</a>
    </td>
    <td>{{note.author}}</td>
    <td>{{note.created_at}}</td>
    {% for field_name in space.list_fields %}
    <td>
      {% if field_name in note.fields %}
        {{note.fields[field_name]}}
      {% else %}
        -
      {% endif %}
    </td>
    {% endfor %}
  </tr>
  {% endfor %}
</table>
{% endblock %}